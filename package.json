    "start": "node scripts/run-vinext.mjs start",
    "test": "npm run build && node --test tests/*.test.mjs",
    "lint": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js . --ignore-pattern dist --ignore-pattern .next",
    "qa:performance:install": "playwright install chromium webkit",
    "qa:performance": "node scripts/browser-performance-budget.mjs",
    "qa:battle-space": "node scripts/run-browser-qa-with-server.mjs scripts/battle-space-browser-smoke.mjs",
    "qa:ai-missions": "node scripts/run-browser-qa-with-server.mjs scripts/ai-mission-browser-smoke.mjs",
    "qa:combat-presentation": "node scripts/run-browser-qa-with-server.mjs scripts/combat-presentation-browser-smoke.mjs",
    "qa:mobile-lifecycle": "node scripts/run-browser-qa-with-server.mjs scripts/mobile-lifecycle-browser-smoke.mjs",
    "qa:save-migration": "node scripts/save-migration-browser-matrix.mjs",
    "qa:station": "node scripts/run-browser-qa-with-server.mjs scripts/station-browser-smoke.mjs",
    "qa:p5": "node scripts/run-browser-qa-with-server.mjs scripts/p5-browser-smoke.mjs",
    "qa:progression": "node scripts/run-browser-qa-with-server.mjs scripts/progression-browser-smoke.mjs",
    "art:v080": "node scripts/build-v080-stage-assets.mjs",
    "content:validate": "node scripts/content-pipeline.mjs validate",
